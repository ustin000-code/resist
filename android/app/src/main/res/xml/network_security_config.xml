<?xml version="1.0" encoding="utf-8"?>
<!-- Явно разрешаем HTTP к API (VITE_API_BASE_URL), иначе на части устройств «Failed to fetch». -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
