# Скопируйте в .env и заполните (секреты в репозиторий не коммитить).

# PostgreSQL
DB_USER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=messenger
DB_PASSWORD=

# API (Express + Socket.IO в server.js)
PORT=3000

# Почта OTP (или Ethereal / Resend — см. mail.service)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
OTP_REQUIRE_SMTP=1

# Регистрация по инвайту
REGISTRATION_INVITE_SECRET=

# Публичные URL (как пользователи открывают сайт / скачивают APK)
INVITE_FRONTEND_URL=http://YOUR_HOST:4173
INVITE_ALLOW_CLIENT_ORIGIN=1
ANDROID_UPDATE_APK_URL=http://YOUR_HOST:3000/download/app.apk

# Push (Firebase)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
