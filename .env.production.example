# Скопируйте в .env.production перед `vite build` (если восстановите исходники фронта).
# Для APK: после build — npm run build:mobile и сборка Android.
#
# ВАЖНО: это публичный URL API с точки зрения клиента (телефон в интернете).
# Не используйте localhost — только IP/домен сервера и порт, куда доступен Node.

VITE_API_BASE_URL=http://YOUR_PUBLIC_HOST:3000
VITE_WS_URL=http://YOUR_PUBLIC_HOST:3000
